{
  "name": "travel-guide",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "format:check": "turbo run format:check",
    "format:write": "turbo run format:write",
    "db:generate": "yarn workspace @travel-guide/web db:generate",
    "db:migrate": "yarn workspace @travel-guide/web db:migrate",
    "db:push": "yarn workspace @travel-guide/web db:push",
    "db:studio": "yarn workspace @travel-guide/web db:studio",
    "db:up": "yarn workspace @travel-guide/web db:up",
    "db:down": "yarn workspace @travel-guide/web db:down"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@1.22.19"
}
