{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_SECRET",
    "AUTH_DISCORD_ID",
    "AUTH_DISCORD_SECRET"
  ],
  "tasks": {
    "generate": {
      "outputs": ["node_modules/.prisma/**"]
    },
    "build": {
      "dependsOn": ["^generate", "^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "check": {
      "dependsOn": ["lint", "typecheck"]
    },
    "format:check": {},
    "format:write": {}
  }
}