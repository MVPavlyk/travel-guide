{
  "name": "@travel-guide/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.6.0"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  }
}
